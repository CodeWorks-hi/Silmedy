<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/bodyImage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:src="@drawable/boby"
        android:scaleType="fitCenter" />

    <ImageView
        android:id="@+id/zoomedPart"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:visibility="gone"
        android:scaleType="fitCenter"
        android:contentDescription="확대된 부위" />

    <LinearLayout
        android:id="@+id/symptomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:gravity="center"
        android:paddingTop="10dp">

        <Button
            android:id="@+id/btnPain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="통증" />

        <Button
            android:id="@+id/btnSwelling"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="부종" />

        <Button
            android:id="@+id/btnItch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="가려움" />
    </LinearLayout>
</LinearLayout>
