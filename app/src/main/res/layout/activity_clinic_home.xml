<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <!-- 🔹 알림 + 환자명 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textWelcome"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="홍길동님, 환영합니다."
            android:textSize="16sp"
            android:textColor="#333333" />

        <ImageView
            android:id="@+id/btnAlarm"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_alarm"
            android:contentDescription="알림 아이콘" />
    </LinearLayout>

    <!-- 🔹 스크롤 가능한 콘텐츠 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:paddingHorizontal="16dp"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 터치로 증상 확인 -->
            <TextView
                android:text="터치로 증상 확인"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_touch_body"
                    android:scaleType="centerInside"
                    android:layout_margin="4dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_symptom_check"
                    android:scaleType="centerInside"
                    android:layout_margin="4dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_call_doctor"
                    android:scaleType="centerInside"
                    android:layout_margin="4dp" />
            </LinearLayout>

            <!-- 가까운 병원 -->
            <TextView
                android:text="가까운 병원"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:src="@drawable/sample_doctor"
                android:scaleType="centerCrop"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="은평서울병원 응급실 · 09:00 - 17:00"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </ScrollView>

</RelativeLayout>
