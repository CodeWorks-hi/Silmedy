<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <!-- 🔹 상단 헤더 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnProfile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_person"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/textWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="홍길동님, 환영합니다."
            android:textSize="14sp"
            android:textColor="#333333" />

        <ImageView
            android:id="@+id/btnAlarm"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_alarm" />
    </LinearLayout>

    <!-- 🔹 본문 스크롤 전체 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 터치로 증상 확인 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="100"
                android:gravity="center_vertical">

                <!-- 좌측 큰 카드 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="48"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/human"
                        android:scaleType="fitCenter" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="터치로 증상확인"
                        android:textSize="13sp"
                        android:textColor="#000"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 우측 2개 세로 카드 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="52"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- 수어 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="8dp"
                        android:layout_marginBottom="6dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/sign_language" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수어동역진료"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- AI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="8dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/consult" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI 증상확인"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 가까운 병원 -->
            <TextView
                android:text="가까운 병원"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:textColor="#000000" />

            <!-- 병원 카테고리 버튼 라인 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:weightSum="5">

                <Button
                    android:id="@+id/btnPediatrics"
                    android:text="소아과"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:backgroundTint="#E6F6F8"
                    android:textColor="#007A87" />

                <Button
                    android:id="@+id/btnInternal"
                    android:text="내과"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#E6F6F8"
                    android:textColor="#007A87" />

                <Button
                    android:id="@+id/btnEyes"
                    android:text="안과"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#E6F6F8"
                    android:textColor="#007A87" />

                <Button
                    android:id="@+id/btnSkin"
                    android:text="피부과"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#E6F6F8"
                    android:textColor="#007A87" />

                <Button
                    android:id="@+id/btnMore"
                    android:text="모두 보기"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#E6F6F8"
                    android:textColor="#3B3BFF" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
